# Copy this file to .env.deploy before using docker-compose.deploy.yml.
python3 scripts/kw_fullstack_compose_smoke.py --repo-root . --timeout 600# Replace all CHANGE_ME values before running a persistent deployment.

APP_ENV=production
DEPLOYMENT_MODE=offline_intranet

POSTGRES_USER=kwstudio
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=kwstudio

DATABASE_URL=postgresql://kwstudio:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/kwstudio
SECRET_KEY=CHANGE_ME_MINIMUM_32_CHAR_SECRET_KEY

METADATA_BACKEND=postgres
STORAGE_BACKEND=local

STORAGE_ROOT=/app/storage
UPLOADS_DIR=/app/storage/uploads
ARTIFACTS_DIR=/app/storage/artifacts
TEMP_DIR=/app/storage/temp

BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Required readiness/provider settings for the approved offline intranet profile.
LLM_PROVIDER=gigachat
GIGACHAT_API_BASE_URL=CHANGE_ME_INTERNAL_GIGACHAT_API_BASE_URL
GIGACHAT_AUTH_URL=CHANGE_ME_INTERNAL_GIGACHAT_AUTH_URL
GIGACHAT_CLIENT_ID=CHANGE_ME_GIGACHAT_CLIENT_ID
GIGACHAT_CLIENT_SECRET=CHANGE_ME_GIGACHAT_CLIENT_SECRET
