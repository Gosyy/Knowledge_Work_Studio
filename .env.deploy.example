# Copy this file to .env.deploy before using docker-compose.deploy.yml.
# Replace all CHANGE_ME values before running a persistent deployment.

APP_ENV=production
DEPLOYMENT_MODE=docker

POSTGRES_USER=kwstudio
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=kwstudio

DATABASE_URL=postgresql://kwstudio:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/kwstudio
SECRET_KEY=CHANGE_ME_MINIMUM_32_CHAR_SECRET_KEY

METADATA_BACKEND=postgres
STORAGE_BACKEND=local

BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional LLM/provider settings for real deployment profiles.
LLM_PROVIDER=
GIGACHAT_API_BASE_URL=
GIGACHAT_AUTH_URL=
