# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Security
SECRET_KEY=change-me
KERNEL_SERVER_AUTH_TOKEN=

# Database
POSTGRES_DB=kw_studio
POSTGRES_USER=kw_studio
POSTGRES_PASSWORD=kw_studio
DATABASE_URL=postgresql+psycopg://kw_studio:kw_studio@postgres:5432/kw_studio

# Storage
STORAGE_ROOT=./storage
UPLOADS_DIR=./storage/uploads
ARTIFACTS_DIR=./storage/artifacts
TEMP_DIR=./storage/temp

# LLM
LLM_PROVIDER=gigachat
GIGACHAT_API_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-Pro
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_TIMEOUT_SECONDS=30
GIGACHAT_VERIFY_SSL=true
FAKE_LLM_RESPONSE=NOOP_LLM_RESPONSE
