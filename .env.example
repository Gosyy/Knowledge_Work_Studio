# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Deployment profile
DEPLOYMENT_MODE=offline_intranet

# Backend
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Security
# Use a real secret from your deployment secret store.
SECRET_KEY=replace-with-a-long-random-secret
KERNEL_SERVER_AUTH_TOKEN=

# Database: Postgres is the single metadata truth layer.
METADATA_BACKEND=postgres
SQLITE_RUNTIME_ALLOWED=false
POSTGRES_DB=kw_studio
POSTGRES_USER=kw_studio
POSTGRES_PASSWORD=replace-with-db-password
DATABASE_URL=postgresql+psycopg://kw_studio:replace-with-db-password@postgres.internal:5432/kw_studio

# Storage: binary truth layer.
# For offline intranet, local means approved internal disk/NAS/mounted remote volume.
STORAGE_BACKEND=local
STORAGE_ROOT=/srv/kw_studio/storage
UPLOADS_DIR=/srv/kw_studio/storage/uploads
ARTIFACTS_DIR=/srv/kw_studio/storage/artifacts
TEMP_DIR=/srv/kw_studio/storage/temp

# MinIO / S3-compatible object storage.
# Use when STORAGE_BACKEND is minio, s3, or remote_object_storage.
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=
STORAGE_VERIFY_TLS=true
STORAGE_ADDRESSING_STYLE=path

# LLM: GigaChat is the only active deployment provider.
LLM_PROVIDER=gigachat
GIGACHAT_API_BASE_URL=https://gigachat-gateway.internal.example/api/v1
GIGACHAT_AUTH_URL=https://gigachat-gateway.internal.example/oauth
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-Pro
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_TIMEOUT_SECONDS=30
GIGACHAT_VERIFY_SSL=true
GIGACHAT_CA_CERT_PATH=
FAKE_LLM_RESPONSE=NOOP_LLM_RESPONSE
